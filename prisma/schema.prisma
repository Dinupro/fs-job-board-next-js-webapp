datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  passwordHash String?
  applications Application[]
}

model Application {
  id                 String   @id @default(uuid())
  userId             String?
  jobId              String
  fullName           String
  email              String
  phone              String
  coverLetter        String
  resumePath         String
  linkedInUrl        String?  // Added
  portfolioGithubUrl String?  // Added
  createdAt          DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
